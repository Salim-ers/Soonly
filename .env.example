# ------------------------------------------------------------------
# Soonly — variables d'environnement
# Copier vers .env.local et renseigner. Aucune valeur n'est commit.
# ------------------------------------------------------------------

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Base de données (PostgreSQL) — Supabase, Neon, Railway, RDS…
DATABASE_URL="postgresql://user:password@localhost:5432/soonly?schema=public"

# Auth.js / NextAuth (openssl rand -base64 32)
AUTH_SECRET="remplacer-par-un-secret-aleatoire"

# Connexion Google (login) — Google Cloud Console > OAuth 2.0
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Chiffrement des tokens OAuth stockés (AES-256-GCM)
# Générer : openssl rand -base64 32   (doit décoder en 32 octets)
ENCRYPTION_KEY=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ESSENTIEL="price_xxx_essentiel_999"
STRIPE_PRICE_PLUS="price_xxx_plus_1499"

# Email (Resend) — magic links + rappels
RESEND_API_KEY=""
EMAIL_FROM="Soonly <rappels@soonly.app>"

# SMS (Twilio) — plan Plus
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# WhatsApp (provider Business API — Twilio Content API ou Meta Cloud API)
WHATSAPP_PROVIDER_TOKEN=""
WHATSAPP_FROM=""

# Web Push (VAPID) — npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:contact@soonly.app"

# Stockage documents (S3-compatible : Supabase Storage, R2, S3…)
STORAGE_BUCKET="soonly-documents"
STORAGE_REGION="auto"
STORAGE_ENDPOINT=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""

# Intégrations calendrier / mail (OAuth) — clés dédiées par provider
GOOGLE_CALENDAR_CLIENT_ID=""
GOOGLE_CALENDAR_CLIENT_SECRET=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT="common"

# Cron sécurisé (Vercel Cron -> /api/reminders/due)
CRON_SECRET="remplacer-par-un-secret-aleatoire"
